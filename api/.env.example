# ── Maximo MIF ────────────────────────────────────────────────────────────────
# Base URL of the Maximo application server — no trailing slash.
# For MAS 9.x on OpenShift the pattern is:
#   https://<manage-host>/maximo
MAXIMO_BASE_URL=https://manage.maspoc.apps.maspoc.zpih.p1.openshiftapps.com/maximo

# Service-account API key for MXINVENTORY queries.
# Generate in Maximo: My Profile → API Keys → Add API Key
MAXIMO_API_KEY=your-api-key-here

# Request timeout for OSLC calls in seconds (default 30)
MAXIMO_TIMEOUT=30

# ── JWT ───────────────────────────────────────────────────────────────────────
# HS256 signing secret.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-64-char-hex-string

# Token lifetime in seconds (default 28800 = 8 hours)
JWT_EXPIRE_SECONDS=28800

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# For local dev: http://localhost:5173
# For OpenShift: add the ingress hostname too.
CORS_ORIGINS=http://localhost:5173

# ── App ───────────────────────────────────────────────────────────────────────
# Set to "production" to disable /docs and /redoc
APP_ENV=development
