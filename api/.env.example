# ── Maximo MIF ────────────────────────────────────────────────────────────────
# Base URL of the Maximo application server — no trailing slash.
# For MAS 9.x on OpenShift the pattern is:
#   https://<manage-host>/maximo
MAXIMO_BASE_URL=https://manage.maspoc.apps.maspoc.zpih.p1.openshiftapps.com/maximo

# Service-account API key for MXINVENTORY queries.
# Generate in Maximo: My Profile → API Keys → Add API Key
MAXIMO_API_KEY=your-api-key-here

# Request timeout for OSLC calls in seconds (default 30)
MAXIMO_TIMEOUT=30

# ── JWT ───────────────────────────────────────────────────────────────────────
# HS256 signing secret.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-64-char-hex-string

# Token lifetime in seconds (default 28800 = 8 hours)
JWT_EXPIRE_SECONDS=28800

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API.
# For local dev: http://localhost:5173
# For OpenShift: add the ingress hostname too.
CORS_ORIGINS=http://localhost:5173

# ── App ───────────────────────────────────────────────────────────────────────
# Set to "production" to disable /docs and /redoc
APP_ENV=development

# ── Q1.1: Persistence ────────────────────────────────────────────────────────
# SQLAlchemy URL.  Dev default below is an on-disk SQLite file.
# Production: postgresql+asyncpg://invopt:<pwd>@<host>:5432/invopt
DATABASE_URL=sqlite+aiosqlite:///./invopt.db
PERSISTENCE_ENABLED=true

# ── Q1.1: WORM audit log ─────────────────────────────────────────────────────
# HMAC secret used to sign each audit row.  Generate the same way as JWT_SECRET.
# Rotating this does NOT invalidate existing chains — each row carries the
# signature it was written with.
AUDIT_HMAC_SECRET=change-me-generate-a-random-64-char-hex-string

# ── Q1.1: Writeback saga ─────────────────────────────────────────────────────
# Master switch for the MIF writeback path.  Leave false until the customer
# has approved the MXINV_INVENTORY_V1 Object Structure + signature options.
WRITEBACK_ENABLED=false
WRITEBACK_OS_NAME=MXINV_INVENTORY_V1
WRITEBACK_MAX_RETRIES=3
WRITEBACK_RETRY_BACKOFF_MS=500

# ── Q1.1: Observability ──────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
LOG_JSON=true
LOG_LEVEL=INFO

# ── Q1.2: Forecasting + optimisation ─────────────────────────────────────────
# Emit a recommendation only when |new − current| / current > this percent.
RECOMMENDATION_DELTA_THRESHOLD_PCT=5.0

# Service-level β routed by criticality (DLD §4.3).
SERVICE_LEVEL_NON_CRITICAL=0.95
SERVICE_LEVEL_CRITICAL=0.99
SERVICE_LEVEL_SAFETY_CRITICAL=0.995

# When true, the per-pattern forecasts use statsforecast (Croston-SBA / AutoETS).
# When false (or statsforecast is not installed) the API falls back to the
# NumPy bootstrap path — still vastly better than the old fixed-spread band.
FORECASTING_USE_STATSFORECAST=true

# ── Q1.2: Scheduler ──────────────────────────────────────────────────────────
# Default off — first run is always operator-initiated via POST :run.
SCHEDULER_ENABLED=false
# 5-field cron expression: minute hour day month day-of-week
SCHEDULER_CRON=0 2 * * *
SCHEDULER_HISTORY_MONTHS=24

# ── Q2.1: Substitution recommender ────────────────────────────────────────────
SUBSTITUTION_EMBEDDING_MODEL=all-MiniLM-L6-v2
SUBSTITUTION_TOP_K=10

# ── Q2.1: Agentic auto-apply ──────────────────────────────────────────────────
# Default OFF — operator flips to true after confirming recommendation quality.
AGENT_AUTO_APPLY_ENABLED=false
AGENT_MAX_DELTA_WC=5000
AGENT_ALLOWED_CRITICALITIES=LOW
AGENT_ALLOWED_TYPES=ROP,SS,EOQ

# ── Q2.2: LLM gateway ────────────────────────────────────────────────────────
# Provider: mock | openai | azure_openai | watsonx
LLM_PROVIDER=mock

# Public OpenAI (sk-... key from platform.openai.com):
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini             # or gpt-4o, gpt-4.1-mini, o1-mini, etc.
#
# Azure OpenAI (model hosted in your Azure tenant):
#   LLM_PROVIDER=azure_openai
#   LLM_ENDPOINT=https://<resource>.openai.azure.com/
#   LLM_API_KEY=<azure key>
#   LLM_DEPLOYMENT=gpt-4o-mini
#
# watsonx:
#   LLM_PROVIDER=watsonx
#   LLM_ENDPOINT=https://us-south.ml.cloud.ibm.com
#   LLM_API_KEY=<IBM Cloud API key>
#   LLM_MODEL=ibm/granite-13b-chat-v2
#   LLM_PROJECT_ID=<watsonx project GUID>
LLM_ENDPOINT=
LLM_API_KEY=
LLM_MODEL=
LLM_DEPLOYMENT=
LLM_PROJECT_ID=
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3
