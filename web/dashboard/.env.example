# .env.example — commit this file; never commit .env.local
# Copy to .env.local and fill in your values

VITE_API_BASE_URL=/v1
VITE_USE_MSW=true

VITE_OIDC_AUTHORITY=https://<your-idp>/.well-known/openid-configuration
VITE_OIDC_CLIENT_ID=invopt-ui-dev
VITE_OIDC_REDIRECT=http://localhost:5173/login/callback

VITE_FEATURE_FLAGS=
VITE_TELEMETRY_URL=

# Codegen helper — only used by `pnpm codegen`, not loaded by Vite
OPENAPI_URL=https://api.invopt.dev.<your-mas-domain>/v1/openapi.json
